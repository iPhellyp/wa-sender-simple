generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WhatsappStatus {
  disconnected
  connecting
  qr
  connected
  error
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
  canceled
}

enum CampaignRecipientStatus {
  pending
  scheduled
  sending
  sent
  failed
  canceled
}

enum WhatsappInstanceRole {
  SALES
  SUPPORT
  BILLING
  POST_SALES
  AFFILIATE
  GENERAL
}

model Contact {
  id              String              @id @default(cuid())
  instanceId      String
  name            String
  phoneRaw        String
  phoneNormalized String
  message         String?             @db.Text
  source          String
  optedOut        Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  instance        WhatsappInstance    @relation(fields: [instanceId], references: [id], onDelete: Restrict)
  recipients      CampaignRecipient[]

  @@unique([instanceId, phoneNormalized])
  @@index([instanceId])
  @@index([source])
  @@index([optedOut])
}

model WhatsappInstance {
  id              String               @id @default(cuid())
  name            String
  phone           String?
  role            WhatsappInstanceRole @default(GENERAL)
  status          WhatsappStatus       @default(disconnected)
  sessionKey      String               @unique
  isDefault       Boolean              @default(false)
  lastConnectedAt DateTime?
  lastSyncAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  contacts        Contact[]
  sessions        WhatsappSession[]
  chats           WhatsappChat[]
  whatsappContacts WhatsappContact[]
  labels          WhatsappLabel[]
  chatLabels      WhatsappChatLabel[]
  messages        WhatsappMessage[]
  campaigns       Campaign[]
  recipients      CampaignRecipient[]
  sendLogs        SendLog[]

  @@index([isDefault])
  @@index([role])
}

model ImportBatch {
  id             String   @id @default(cuid())
  filename       String
  totalRows      Int
  insertedRows   Int
  duplicatedRows Int
  invalidRows    Int
  createdAt      DateTime @default(now())
}

model WhatsappSession {
  id             String         @id @default(cuid())
  instanceId     String
  status         WhatsappStatus @default(disconnected)
  qrCode         String?        @db.Text
  connectedPhone String?
  lastError      String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  instance       WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model WhatsappChat {
  id              String              @id @default(cuid())
  instanceId      String
  jid             String
  name            String?
  isGroup         Boolean             @default(false)
  unreadCount     Int                 @default(0)
  lastMessageAt   DateTime?
  lastMessageText String?             @db.Text
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  instance        WhatsappInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  messages        WhatsappMessage[]
  labels          WhatsappChatLabel[]

  @@unique([instanceId, jid])
  @@index([instanceId, jid])
  @@index([lastMessageAt])
  @@index([isGroup])
}

model WhatsappContact {
  id         String   @id @default(cuid())
  instanceId String
  jid        String
  phone      String?
  name       String?
  pushName   String?
  isBusiness Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  instance   WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, jid])
  @@index([instanceId, phone])
  @@index([phone])
}

model WhatsappMessage {
  id          String       @id @default(cuid())
  instanceId  String
  chatId      String
  waMessageId String
  jid         String
  fromMe      Boolean      @default(false)
  senderJid   String?
  timestamp   DateTime?
  messageType String?
  text        String?      @db.Text
  rawJson     Json?
  createdAt   DateTime     @default(now())
  instance    WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  chat        WhatsappChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([instanceId, jid, waMessageId])
  @@index([instanceId, jid])
  @@index([chatId, timestamp])
  @@index([fromMe])
  @@index([jid])
}

model WhatsappLabel {
  id         String              @id @default(cuid())
  instanceId String
  waLabelId  String
  name       String
  color      String?
  predefined Boolean             @default(false)
  deleted    Boolean             @default(false)
  rawJson    Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  instance   WhatsappInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  chats      WhatsappChatLabel[]
  campaigns  Campaign[]

  @@unique([instanceId, waLabelId])
  @@index([instanceId, waLabelId])
  @@index([deleted])
}

model WhatsappChatLabel {
  id        String        @id @default(cuid())
  instanceId String
  chatId    String
  labelId   String
  jid       String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  instance  WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  chat      WhatsappChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  label     WhatsappLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([instanceId, chatId, labelId])
  @@index([instanceId, jid])
  @@index([jid])
  @@index([labelId])
}

model Campaign {
  id                     String              @id @default(cuid())
  instanceId             String
  name                   String
  defaultMessage         String?             @db.Text
  intervalMinutes        Int
  status                 CampaignStatus      @default(draft)
  targetMode             String              @default("manual")
  targetLabelId          String?
  excludeGroups          Boolean             @default(true)
  excludeAlreadySentDays Int?
  dedupeKey              String?
  maxRecipients          Int?
  sendWindowStart        String?
  sendWindowEnd          String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  scheduledAt            DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  mediaKind              String?
  mediaPath              String?
  mediaOriginalName      String?
  mediaMimeType          String?
  mediaSizeBytes         Int?
  lastError              String?             @db.Text
  instance               WhatsappInstance    @relation(fields: [instanceId], references: [id], onDelete: Restrict)
  recipients             CampaignRecipient[]
  sendLogs               SendLog[]
  targetLabel            WhatsappLabel?      @relation(fields: [targetLabelId], references: [id], onDelete: SetNull)

  @@index([instanceId, createdAt])
  @@index([instanceId, status, scheduledAt])
  @@index([status])
  @@index([targetMode])
  @@index([targetLabelId])
}

model CampaignRecipient {
  id           String                  @id @default(cuid())
  instanceId   String
  campaignId   String
  contactId    String?
  chatId       String?
  jid          String?
  messageFinal String                  @db.Text
  status       CampaignRecipientStatus @default(pending)
  dedupeKey    String?
  skippedReason String?                @db.Text
  attemptCount Int                     @default(0)
  lastAttemptAt DateTime?
  scheduledAt  DateTime?
  sentAt       DateTime?
  error        String?                 @db.Text
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  instance     WhatsappInstance        @relation(fields: [instanceId], references: [id], onDelete: Restrict)
  campaign     Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact?                @relation(fields: [contactId], references: [id], onDelete: Restrict)
  sendLogs     SendLog[]

  @@unique([campaignId, contactId])
  @@unique([campaignId, jid])
  @@index([instanceId, campaignId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([jid])
  @@index([dedupeKey])
}

model SendLog {
  id          String             @id @default(cuid())
  instanceId  String
  jid         String
  chatId      String?
  campaignId  String?
  recipientId String?
  messageHash String?
  status      String
  error       String?            @db.Text
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  instance    WhatsappInstance    @relation(fields: [instanceId], references: [id], onDelete: Restrict)
  campaign    Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipient   CampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([instanceId, jid, sentAt])
  @@index([jid, sentAt])
  @@index([campaignId])
  @@index([recipientId])
  @@index([messageHash])
}
